# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Environment files (NEVER commit secrets) ─────────────────────────────────
.env
.env.local
.env.*.local
# backend/.env already covered above

# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
.vite/

# ─── Database files ───────────────────────────────────────────────────────────
backend/db/stryper.db
backend/db/stryper.db-shm
backend/db/stryper.db-wal
backend/db/stryper.json

# ─── Uploaded files (served from Cloudinary in production) ────────────────────
backend/uploads/images/*
backend/uploads/resumes/*
!backend/uploads/images/.gitkeep
!backend/uploads/resumes/.gitkeep

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ─── OS files ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editor ──────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ─── Vite / React ────────────────────────────────────────────────────────────
*.local
